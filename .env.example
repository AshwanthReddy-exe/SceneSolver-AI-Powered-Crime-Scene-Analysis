# ---------------------------------------------------------
# SceneSolver System Environment Variables
# Copy this file to backend/.env and update the values
# ---------------------------------------------------------

# ========== Node.js Auth Server Settings ==========
# The port where Express Auth server will run
PORT=8080

# MongoDB Connection String (Replace with your actual MongoDB URI)
MONGO_CONN="mongodb+srv://<username>:<password>@cluster0.mongodb.net/SceneSolver?retryWrites=true&w=majority"

# JWT Secret for Auth Token generation
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY"

# ========== Python AI API Server Settings ==========
# (Typically runs on port 5000, optional config can go here)
# FLASK_ENV=development
# FLASK_DEBUG=1
